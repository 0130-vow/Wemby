{
  "name": "wemby",
  "version": "0.1.5",
  "description": "A personal Windows Emby client focused on fast launch, smooth playback, and MPV-powered seeking.",
  "main": "src/main.js",
  "scripts": {
    "postinstall": "node scripts/ensure-mpv.js --optional",
    "start": "electron .",
    "dev": "electron .",
    "lint": "node --check src/main.js && node --check src/preload.js && node --check src/renderer.js && node --check scripts/ensure-mpv.js",
    "prepare-mpv": "node scripts/ensure-mpv.js",
    "build:win": "electron-builder --win",
    "dist:win": "npm run prepare-mpv && npm run build:win",
    "pack:win": "npm run prepare-mpv && electron-builder --win --dir"
  },
  "keywords": [
    "emby",
    "windows",
    "mpv",
    "electron"
  ],
  "author": "",
  "license": "MIT",
  "build": {
    "appId": "com.wemby.player",
    "productName": "Wemby",
    "asar": true,
    "files": [
      "src/**/*",
      "package.json",
      "README.md"
    ],
    "extraResources": [
      {
        "from": "vendor/mpv",
        "to": "vendor/mpv",
        "filter": [
          "**/*"
        ]
      }
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "artifactName": "${productName}-${version}-${arch}-setup.${ext}",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Wemby"
    },
    "portable": {
      "artifactName": "${productName}-${version}-${arch}-portable.${ext}"
    }
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^26.15.3"
  }
}
